---
import BaseLayout from '~/layouts/BaseLayout.astro'
import TabbedLayout from '~/layouts/TabbedLayout.astro'
import ListView from '~/components/views/ListView.astro'
import SubNav from '~/components/nav/SubNav.astro'
import { UI, SITE } from '~/config'

export async function getStaticPaths() {
  const { blogCategories = [] } = UI
  return blogCategories
    .filter((cat) => cat.path !== '/post')
    .map((category) => ({
      params: { id: category.id },
      props: { category },
    }))
}

const { category } = Astro.props
---

<BaseLayout
  title={`${category.title} - ${SITE.title}`}
  description={SITE.description}
  bgType="plum"
  ogImage={false}
>
  <TabbedLayout>
    <SubNav />
    <ListView collectionType="blog" categoryId={category.categoryId} />
  </TabbedLayout>
</BaseLayout>
