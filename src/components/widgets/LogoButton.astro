<style>
  .logo-container {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.8rem;

    transform: scale(1.05);
  }

  @media (max-width: 767.9px) {
    .logo-container {
      margin-top: 0.125rem;

      transform-origin: 0%;
      transform: scale(0.95);
    }
  }

  .logo-container svg {
    height: 2rem;
  }
  .animated-path-O {
    stroke-dasharray: 100;
    stroke-dashoffset: 100;
    animation: drawLogo 0.8s ease-in forwards;
  }
  .animated-path-l,
  .animated-path-s,
  .animated-path-ond {
    stroke-dasharray: 100;
    stroke-dashoffset: 100;
  }
  .animated-path-l {
    animation: drawLogo 0.4s ease-in-out forwards;
    animation-delay: 0.8s;
  }
  .animated-path-s {
    animation: drawLogo 0.45s ease-in-out forwards;
    animation-delay: 1.2s;
  }
  .animated-path-ond {
    animation: drawLogo 1.35s ease-out forwards;
    animation-delay: 1.65s;
  }
  @keyframes drawLogo {
    to {
      stroke-dashoffset: 0;
    }
  }
</style>
